# ─── Server ────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ──────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/finance-dashboard

# ─── Authentication ────────────────────────────────
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRES_IN=7d

# ─── Rate Limiting ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
